  m_Script: {fileID: 11500000, guid: 7fcd6b2b2a5a5e641a7056c49dfd484f, type: 3}
  m_Name: How to make money
  m_EditorClassIdentifier: Assembly-CSharp::ShopkeepDialogue_Def
  shopkeepText: You can make money by slaying monsters, crafting items and selling
    them, and betting on the horse races. But these mechanics aren't implemented
    yet so in the meantime you can answer my questions and I'll give you cash if
    you answer correctly.
  playerLines:
  - text: Sounds great! Give me your riddles, shopkeep!
    dialogueDef: {fileID: 11400000, guid: 7ff8f7811e6f62a46891e916d5bcca8a, type: 2}
    isGoodbye: 0
  - text: Why would I even want any money?
    dialogueDef: {fileID: 11400000, guid: eb3738ec142d0f145991012ca688cedc, type: 2}
    isGoodbye: 0
  - text: Nah, I'm good thanks
    dialogueDef: {fileID: 11400000, guid: 6a47aeff3dc3a5841b165e9d7f6327f4, type: 2}
    isGoodbye: 0
