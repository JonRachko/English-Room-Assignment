MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7fcd6b2b2a5a5e641a7056c49dfd484f, type: 3}
  m_Name: Question 1
  m_EditorClassIdentifier: Assembly-CSharp::ShopkeepDialogue_Def
  shopkeepText: 'First Question: What is a ScriptableObject and why is it useful?
    When would you use one instead of a MonoBehaviour?'
  playerLines:
  - text: ScriptableObjects? Monobehaviours? I'm here to fight monsters man!
    dialogueDef: {fileID: 11400000, guid: d5496909d1f339c4294b2d60c601766c, type: 2}
    isGoodbye: 0
  - text: ScriptableObjects are not useful. I'm outta here.
    dialogueDef: {fileID: 0}
    isGoodbye: 1
  - text: ScriptableObjects are Unity's data classes. They live as assets outside
      of scenes and are used to hold structured information that can be retrieved
      at runtime to fill the variables of different kinds of objects, such as store
      item cards or dialogue text options.
    dialogueDef: {fileID: 11400000, guid: 7f4dd1cc2f72e8641a5f020803d198e3, type: 2}
    isGoodbye: 0
